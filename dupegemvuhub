--// BLUE SKY AFK LOOP
--// Bật = tự gửi true liên tục
--// Tắt = tự gửi false
--// Loop vô hạn tới khi tắt

local Running = false
local Threads = 100

local Remote = game:GetService("ReplicatedStorage")
    :WaitForChild("RS")
    :WaitForChild("RGX")
    :WaitForChild("RIO")

local UIS = game:GetService("UserInputService")

local function Fire(v)
    Remote:FireServer("afk", v)
end

