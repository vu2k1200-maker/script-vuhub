local function patchTPSlots()
	for _,row in pairs(scroll:GetChildren()) do
		if row:IsA("Frame") then

			local buttons = {}

			for _,obj in pairs(row:GetChildren()) do
				if obj:IsA("TextButton") then
					table.insert(buttons,obj)
				end
			end

			for _,btn in pairs(buttons) do
				if btn.Text == "TP" then

					btn.MouseButton1Click:Connect(function()
						local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
						local pos = row:GetAttribute("SavedPos")

						if hrp and pos then

							if TweenTP then
								local dist = (hrp.Position - pos).Magnitude
								local time = math.clamp(dist / 120,0.5,5)

								TweenService:Create(
									hrp,
									TweenInfo.new(time,Enum.EasingStyle.Linear),
									{CFrame = CFrame.new(pos)}
								):Play()
							else
								hrp.CFrame = CFrame.new(pos)
							end

							-- TP VEHICLE
							if TPPlayerVehicle then
								for _,v in pairs(workspace:GetDescendants()) do
									if v:IsA("VehicleSeat") then
										v.CFrame = CFrame.new(pos + Vector3.new(6,0,0))
										break
									end
								end
							end
						end
					end)
				end
			end
		end
	end
end

