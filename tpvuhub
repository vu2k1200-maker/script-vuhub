--========================
toggle.MouseButton1Click:Connect(function()
	opened = not opened

	if opened then
		menu.Visible = true
		TweenService:Create(menu,TweenInfo.new(0.3,Enum.EasingStyle.Back),{
			Size = openSize
		}):Play()
	else
		local t = TweenService:Create(menu,TweenInfo.new(0.25),{
			Size = UDim2.new(0,0,0,0)
		})
		t:Play()
		t.Completed:Wait()
		menu.Visible = false
	end
