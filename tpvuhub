local function createConfigSlot(cfgName,dataLoaded)
	local row = Instance.new("Frame")
	row.Parent = cfgScroll
	row.Size = UDim2.new(1,-5,0,42)
	row.BackgroundColor3 = Color3.fromRGB(235,245,255)
	Instance.new("UICorner",row).CornerRadius = UDim.new(0,10)

	local name = Instance.new("TextBox")
	name.Parent = row
	name.Size = UDim2.new(0.28,0,1,0)
	name.BackgroundTransparency = 1
	name.Text = cfgName or "Config"
	name.ClearTextOnFocus = false
	name.Font = Enum.Font.GothamBold
	name.TextSize = 15
	name.TextColor3 = Color3.fromRGB(70,130,180)

	local function mk(txt,x,col)
		local b = Instance.new("TextButton")
		b.Parent = row
		b.Position = UDim2.new(x,0,0.12,0)
		b.Size = UDim2.new(0.20,0,0.76,0)
		b.Text = txt
		b.Font = Enum.Font.GothamBold
		b.TextSize = 12
		b.TextColor3 = Color3.new(1,1,1)
		b.BackgroundColor3 = col
		Instance.new("UICorner",b).CornerRadius = UDim.new(0,8)
		return b
	end

	local save = mk("Save",0.30,Color3.fromRGB(100,200,120))
	local load = mk("Load",0.53,Color3.fromRGB(135,206,250))
	local del = mk("Delete",0.76,Color3.fromRGB(255,120,120))

	if dataLoaded then
		row:SetAttribute("ConfigData",dataLoaded)
	end

	-- SAVE CONFIG
	save.MouseButton1Click:Connect(function()
		row:SetAttribute("ConfigData",collectTPSlots())
		saveFile()
	end)

	-- LOAD CONFIG
	load.MouseButton1Click:Connect(function()
		local data = row:GetAttribute("ConfigData")
		if data then
			loadTPSlots(data)
		end
	end)

	-- DELETE
	del.MouseButton1Click:Connect(function()
		row:Destroy()
		saveFile()
	end)
end

