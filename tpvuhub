local function collectTPSlots()
	local data = {}

	for _,row in pairs(scroll:GetChildren()) do
		if row:IsA("Frame") then
			local name = row:FindFirstChildOfClass("TextBox")
			local pos = row:GetAttribute("SavedPos")

			if name and pos then
				table.insert(data,{
					name = name.Text,
					x = pos.X,
					y = pos.Y,
					z = pos.Z
				})
			end
		end
	end

	return data
end

--========================
-- LOAD SLOT DATA TO TAB1
--========================
local function loadTPSlots(data)
	for _,v in pairs(scroll:GetChildren()) do
		if v:IsA("Frame") then
			v:Destroy()
		end
	end

	slotCount = 0

	for _,info in pairs(data) do
		createSlot(
			info.name,
			Vector3.new(info.x,info.y,info.z)
		)
	end
end

--========================
-- SAVE FILE
--========================
local function saveFile()
	if writefile then
		local list = {}

		for _,row in pairs(cfgScroll:GetChildren()) do
			if row:IsA("Frame") and row:GetAttribute("ConfigData") then
				table.insert(list,{
					name = row:FindFirstChildOfClass("TextBox").Text,
					data = row:GetAttribute("ConfigData")
				})
			end
		end

		writefile(FILE_NAME,HttpService:JSONEncode(list))
	end
end

